# =============================================================================
# Auto-generated values (setup.sh auto-detects, do not edit manually)
# =============================================================================
USER_NAME=
USER_GROUP=
USER_UID=1000
USER_GID=1000
HARDWARE=x86_64
DOCKER_HUB_USER=
GPU_ENABLED=false
IMAGE_NAME=gemini_cli

# =============================================================================
# Workspace path (absolute path mounted into container ~/work)
# =============================================================================
WS_PATH=../workspace

# =============================================================================
# Base image (auto-derived from GPU_ENABLED by post_setup.sh)
# CPU:  node:20-slim
# GPU:  nvidia/cuda:13.1.1-cudnn-devel-ubuntu24.04
# =============================================================================
# BASE_IMAGE=node:20-slim
# GPU_VARIANT=false

# =============================================================================
# Optional: override host credential directory
# =============================================================================
# GEMINI_HOST_DIR=~/.gemini

# =============================================================================
# Session data directory (conversations, settings, etc.)
# Stored on host as bind mount, easy to copy/backup
# =============================================================================
# DATA_DIR=./data
